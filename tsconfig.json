{
	"compilerOptions": {
		"noEmit": true,
		"inlineSourceMap": true,
		"inlineSources": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"module": "ESNext",
		"types": [
			"obsidian-typings",
			"uniformize"
		],
		"target": "ESNext",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"strictNullChecks": true,
		"lib": ["DOM", "ES5", "ES6", "ES7", "ES2015", "ES2021", "ES2022"]
	},
	"include": ["**/*.ts"],
	"exclude": ["tests/**/*.ts"]
}
